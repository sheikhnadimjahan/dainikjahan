{
  "name": "dainik-jahan",
  "version": "1.0.0",
  "description": "AI-powered Bengali newspaper CMS - Dainik Jahan",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation payload build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "^3.0.0",
    "@payloadcms/db-mongodb": "^3.0.0",
    "@payloadcms/live-preview-react": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/plugin-form-builder": "^3.0.0",
    "@payloadcms/plugin-nested-docs": "^3.0.0",
    "@payloadcms/plugin-redirects": "^3.0.0",
    "@payloadcms/plugin-search": "^3.0.0",
    "@payloadcms/plugin-seo": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/ui": "^3.0.0",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-label": "^2.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cross-env": "10.1.0",
    "dotenv": "16.4.7",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "lucide-react": "0.563.0",
    "next": "16.2.7",
    "next-sitemap": "^4.2.3",
    "payload": "^3.0.0",
    "prism-react-renderer": "^2.3.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.71.1",
    "sharp": "0.34.2",
    "tailwind-merge": "^3.4.0",
    "axios": "^1.6.0",
    "feed": "^4.2.2",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.7",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.1.18",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=18.17.0",
    "pnpm": "^9 || ^10 || ^11"
  }
}
